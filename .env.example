VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# In Google Cloud Console enable at least: Maps JavaScript API, Geocoding API,
# and Places API (New). Legacy PlacesService is not available to new projects (as of Mar 2025).

# GA4 measurement ID (Web data stream, format G-XXXXXXXXXX). Omit to skip analytics.
# Must be present at **build** time (e.g. Cloudflare Pages env vars), then redeploy.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Phase 0 feature flag — set to "true" to expose the email magic-link "Sign in"
# UI and activate localStorage→D1 passport sync. Default off so the SPA stays
# pure-anonymous. Flip after Resend + .dev.vars are configured.
# VITE_AUTH_ENABLED=true
