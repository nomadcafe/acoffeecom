# Normalize bare locale paths to trailing-slash canonical form so search
# engines crawling /en (which Cloudflare Pages otherwise 308s to /) land on
# the actual locale home instead of the root fallback.
/en    /en/   301
/ja    /ja/   301
/zh    /zh/   301

/en/*  /index.html   200
/ja/*  /index.html   200
/zh/*  /index.html   200

# Missing hashed assets (typical after a new deploy rotates chunk filenames)
# must 404 instead of falling through to the SPA fallback below. Serving
# index.html for a stale /assets/*.js request would make the browser load
# HTML as a module and report "Expected a module, got text/html". Netlify
# applies this rule only when the file is absent from the publish dir, so
# real assets still serve normally.
/assets/*  /assets/:splat  404

# SPA fallback: any other path (e.g. bare /passport, /updatelog) is routed
# client-side. Netlify evaluates rules top-down and skips this for real
# files in the build output (assets, sitemap, manifest, sw), so hashed JS
# and the service worker still serve normally.
/*     /index.html   200
