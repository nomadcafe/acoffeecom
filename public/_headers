# Cloudflare Pages applies the most specific block that matches a request.
# Layout: /assets/* (long-cache for hashed chunks), /api/* (no shared cache
# for authenticated JSON), /* (everything else — SPA shell + manifest +
# sw.js + logo + robots).
#
# CSP notes:
#   - 'sha256-...' below is the hash of the inline <script type="application/
#     ld+json"> in index.html. Any change to that block requires recomputing
#     it via:  awk '/<script type="application\/ld\+json">/,/<\/script>/' \
#                index.html | sed '1d;$d' | openssl dgst -sha256 -binary | base64
#   - 'unsafe-inline' on style-src is needed because Google Maps SDK and
#     several React libraries inject inline styles. We keep script-src strict.
#   - *.googleapis.com is wildcarded under connect-src because the Maps SDK
#     fans out to places.googleapis.com / routes.googleapis.com / etc.
#   - googletagmanager + google-analytics are listed for the optional GA
#     loader (initGoogleAnalytics.ts); harmless when GA isn't configured.
#   - lh3.googleusercontent.com covers OAuth avatar URLs from Google sign-in.
#   - Two pub-*.r2.dev hosts cover AVATARS + PLACE_PHOTOS buckets. Move to a
#     custom domain later so we can set our own headers on those origins.

# Long-cached hashed assets — Vite emits hashed filenames so immutable is safe.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# API responses must never be shared-cached. The /* rule sets `public,
# max-age=0, must-revalidate` which would let an intermediary cache an
# auth-bound response and serve it to a different user.
/api/*
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Everything else: SPA shell, /sw.js, /manifest.webmanifest, /logo.png,
# /robots.txt. Browsers must re-validate every load so a fresh deploy's
# hashed asset URLs (referenced from the rebuilt index.html) get picked up
# immediately. Without this, a cached old index.html keeps pointing at
# /assets/*.css chunks that no longer exist.
/*
  Cache-Control: public, max-age=0, must-revalidate
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://accounts.google.com; script-src 'self' 'sha256-q56LdmGcnFh9uZjg4g+1oeEtcpwEVwLMjZZhe2GhaG0=' https://maps.googleapis.com https://maps.gstatic.com https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://lh3.googleusercontent.com https://*.googleusercontent.com https://maps.googleapis.com https://maps.gstatic.com https://*.google.com https://*.googleapis.com https://pub-8047aed0e1084fc3b99f34b3bb637d65.r2.dev https://pub-dd937f8ea2cb40c1b5271c1d62bcd678.r2.dev https://www.google-analytics.com https://www.googletagmanager.com; connect-src 'self' https://maps.googleapis.com https://*.googleapis.com https://www.gstatic.com https://ipapi.co https://www.google-analytics.com https://*.analytics.google.com; worker-src 'self' blob:; manifest-src 'self'; frame-src 'self' https://*.google.com; upgrade-insecure-requests
